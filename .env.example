# DARWIN Configuration
# Copy this file to .env and fill in your values

# ── OKX API credentials ────────────────────────────────────────────────────────
# Get from OKX → API Management
# IMPORTANT: Use a sub-account with demo trading enabled
# NEVER use your main account for automated trading
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_DEMO_MODE=true

# ── Risk configuration ─────────────────────────────────────────────────────────
# Options: conservative | balanced | aggressive
#   conservative: 5% max drawdown, 30% pool
#   balanced:     15% max drawdown, 50% pool
#   aggressive:   30% max drawdown, 70% pool
RISK_TIER=balanced

# ── Asset whitelist ─────────────────────────────────────────────────────────────
# Comma-separated trading pairs. AI selects among these based on market conditions.
# Strategies use wildcard ["*"] to auto-expand to all whitelisted assets.
# Example: only BTC+ETH → ASSETS=BTC-USDT,ETH-USDT
ASSETS=BTC-USDT,ETH-USDT,SOL-USDT,DOGE-USDT,XRP-USDT,AVAX-USDT

# ── Heartbeat interval ─────────────────────────────────────────────────────────
HEARTBEAT_MINUTES=15

# ── LLM enrichment (completely optional — 0 keys = pure rule-based) ────────────
# Set ANY key below to enable; first available wins.
# LLM_PROVIDER_ORDER=deepseek,anthropic,groq,ollama
#
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5

# ── Paperclip Agent Org ─────────────────────────────────────────────────────────
PAPERCLIP_URL=http://127.0.0.1:3100
PAPERCLIP_BRIDGE_PORT=3200
PAPERCLIP_COMPANY_ID=
PAPERCLIP_AGENT_CTO=
PAPERCLIP_AGENT_MARKET=
PAPERCLIP_AGENT_RISK=
PAPERCLIP_AGENT_STRATEGY_MANAGER=
PAPERCLIP_AGENT_AUDITOR=

# ── Telegram notifications (optional) ────────────────────────────────────────
# Bot token from @BotFather, chat ID from @userinfobot
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ═══════════════════════════════════════════════════════════════════════════════
# Quick Start:
#   1. cp .env.example .env
#   2. Fill in OKX_API_KEY, OKX_SECRET_KEY, OKX_PASSPHRASE (demo sub-account)
#   3. pnpm install
#   4. pnpm run bridge        ← Start dashboard at http://127.0.0.1:3200
#   5. pnpm run demo:a        ← Run demo scenario (separate terminal)
#   6. pnpm run backtest      ← Run 90-day backtest
# ═══════════════════════════════════════════════════════════════════════════════
